---
import { getEntry } from 'astro:content';
const settings = await getEntry('settings', 'settings');

interface Props {
  message?: string;
}
const { message = 'היי מעיין, הגעתי מהאתר ואשמח לשמוע פרטים נוספים 🙂' } = Astro.props;

const href = settings?.data.whatsapp
  ? `${settings.data.whatsapp}?text=${encodeURIComponent(message)}`
  : undefined;
---
{href && (
  <a
    class="floating-whatsapp"
    href={href}
    target="_blank"
    rel="noopener"
    aria-label="שליחת הודעת וואטסאפ"
    title="שליחת הודעת וואטסאפ"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" fill="currentColor" aria-hidden="true">
      <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.85 9.85 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.91C21.96 6.45 17.5 2 12.04 2Zm0 18.15h-.01a8.2 8.2 0 0 1-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.19 8.19 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.25-8.24 2.2 0 4.27.86 5.83 2.42a8.19 8.19 0 0 1 2.41 5.83c0 4.55-3.7 8.23-8.24 8.23Zm4.52-6.17c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.78.97-.15.17-.29.19-.54.06-.25-.12-1.04-.38-1.98-1.22-.73-.65-1.23-1.46-1.37-1.7-.15-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.15.16-.25.24-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.85-.2-.48-.41-.42-.56-.43-.15-.01-.31-.01-.48-.01-.16 0-.43.06-.66.31-.22.25-.87.85-.87 2.07 0 1.22.89 2.4 1.02 2.57.12.16 1.75 2.67 4.25 3.74.59.26 1.06.41 1.42.52.6.19 1.14.16 1.57.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.08.15-1.18-.06-.1-.23-.16-.48-.28Z" />
    </svg>
  </a>
)}
<style>
  .floating-whatsapp {
    position: fixed;
    inset-inline-start: 1.25rem;
    bottom: 1.25rem;
    z-index: 200;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: #25d366;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.3);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .floating-whatsapp:hover {
    transform: scale(1.08);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.35);
  }
  .floating-whatsapp svg {
    width: 1.85rem;
    height: 1.85rem;
  }
  @media (max-width: 640px) {
    .floating-whatsapp {
      width: 3.1rem;
      height: 3.1rem;
      inset-inline-start: 1rem;
      bottom: 1rem;
    }
    .floating-whatsapp svg {
      width: 1.6rem;
      height: 1.6rem;
    }
  }
</style>
