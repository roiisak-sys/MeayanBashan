---
import SocialIcons from './SocialIcons.astro';
---
<footer class="site-footer">
  <img class="footer-logo" src="/images/logo-white.png" alt="מעיין בשן" />
  <p>© {new Date().getFullYear()} מעיין בשן. כל הזכויות שמורות.</p>
  <div class="socials">
    <SocialIcons />
  </div>
</footer>
<style>
  .site-footer {
    padding: 2.5rem 2rem;
    text-align: center;
    background: var(--ink);
    background-image: var(--grain);
    color: var(--paper);
  }
  .site-footer p {
    opacity: 0.75;
    font-size: 0.9rem;
  }
  .socials {
    margin-top: 0.85rem;
    color: var(--paper);
  }
  .footer-logo {
    height: 26px;
    width: auto;
    margin: 0 auto 0.85rem;
  }
</style>
