---
import { getCollection } from 'astro:content';
const logos = await getCollection('partner_logos');
---
{logos.length > 0 && (
  <section class="partner-logos section-ink">
    <span class="eyebrow eyebrow-orange">כפי שהופיעה ב</span>
    <div class="logos-grid">
      {logos.map((logo) => (
        <img src={logo.data.logo} alt={logo.data.name} loading="lazy" />
      ))}
    </div>
  </section>
)}
<style>
  .partner-logos {
    padding: 2.5rem 2rem;
    text-align: center;
  }
  .partner-logos .eyebrow { text-align: center; margin-bottom: 1.5rem; font-size: 1rem; }
  .logos-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 2rem;
  }
  .logos-grid img { height: 56px; }
</style>
