---
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const PAYMENT_URL = 'https://secure.cardcom.solutions/EA/EA5/4SwsNP9VJ0ueOlqA9OOBzg/PaymentSP';

const dates = ['שישי 23.10', 'שישי 30.10', 'שישי 13.11', 'שישי 20.11', 'שישי 27.11'];

const outcomes = [
  {
    title: 'לתפוס רגש לפני שהוא נאמר',
    text: 'מיקרו-הבעות נמשכות שבריר שנייה — ורוב האנשים מפספסים אותן. תתאמנו לזהות אותן בזמן אמת, עד שתדעו מה מישהו מרגיש לפני שהוא בוחר מה לומר לכם.',
  },
  {
    title: 'לדעת מתי משהו לא נכון',
    text: 'שקר משאיר חמישה סימנים שגוף לא יכול להסתיר, גם כשהמילים מתוזמנות לדייק. תלמדו לקרוא אותם — ותפסיקו להאמין רק כי המשפט נשמע משכנע.',
  },
  {
    title: 'לשלוט בקצב הקריאה שלכם',
    text: 'המיקרו-מבט קולט פרט בודד; המאקרו-שדר קורא את התמונה כולה. עם שחקן מול הקבוצה תתרגלו לעבור בין השניים בלייב — לא בתיאוריה, בסימולציה אמיתית עם קול ולחץ זמן.',
  },
  {
    title: 'להיכנס לחדר בלי לדבר',
    text: 'נוכחות נקראת לפני שפותחים את הפה — ביציבה, בקצב הנשימה, באופן שבו עומדים. תעבדו על הגרסה שלכם, לא על חיקוי, כך שהביטחון יישאר אמיתי גם תחת לחץ.',
  },
  {
    title: 'להשפיע בלי שירגישו שהשפעתם',
    text: 'הצד השני קולט תת-הכרתית הרבה לפני שהוא מודע לזה. תלמדו להוביל שיחה ולשתול נקודת מבט באמצעות הגוף שלכם — באופן שמרגיש לצד השני כמו ההחלטה שלו.',
  },
];

const faqs = [
  {
    q: 'אני לא טוב/ה בזיהוי סימנים. זה לא מסובך מדי?',
    a: 'הקורס בנוי הדרגתית, עם שיטה פשוטה ותרגול מעשי בכל שלב. גם משתתפים ללא שום רקע קודם הצליחו לפתח מיומנות מדהימה.',
  },
  {
    q: 'מה אם אפסיד מפגש אחד?',
    a: 'אפשר להשלים בקורס הבא או לקבל גישה להקלטת המפגש שהחסרתם.',
  },
  {
    q: 'רלוונטי גם מי שלא במכירות או ניהול?',
    a: 'בהחלט. הקורס מתאים להורים, בני זוג, סטודנטים, ולכל מי שרוצה להבין טוב יותר את האנשים סביבו.',
  },
  {
    q: 'זה באמת ישפיע על החיים שלי?',
    a: 'משתתפים רבים מדווחים על שינויים משמעותיים כבר מהמפגש הראשון — בזוגיות, בהורות, בפגישות עסקיות ובביטחון האישי.',
  },
  {
    q: 'אני לומד/ת כבר תקשורת בינאישית. זה חופף?',
    a: 'שפת הגוף היא רובד עמוק ומשלים. מה שתלמדו כאן יעמיק ויחזק כל ידע קיים.',
  },
  {
    q: 'מה תנאי הביטול?',
    a: 'ביטול והחזר מלא אפשרי עד שבוע לפני תחילת הקורס.',
  },
];
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>קורס ניתוח גוף פתוח | מעיין בשן</title>
    <meta name="description" content="הכשרה אינטנסיבית בשפת גוף עם מעיין בשן — 5 מפגשים, אוקטובר-נובמבר 2026, הרצליה" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@400;600;700;800&family=Heebo:wght@700;800;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="lp-nav">
      <a href="/" class="lp-logo"><img src="/images/logo-teal.png" alt="מעיין בשן" /></a>
      <a href="#register" class="lp-nav-cta">הרשמה לקורס</a>
    </nav>

    <section class="lp-hero">
      <div class="lp-hero-text">
        <div class="lp-eyebrow-pill">✦ קורס ניתוח גוף פתוח</div>
        <h1>לקרוא אנשים כמו<br /><em>ספר פתוח</em></h1>
        <p class="lp-hero-sub">הכשרה אינטנסיבית בשפת גוף עם מעיין בשן —<br />5 מפגשים שיעניקו לך כוחות על אנושיים</p>
        <ul class="lp-bullets">
          <li>לזהות שקרים ומניפולציות לפני שהצד השני מסיים משפט</li>
          <li>לשדר ביטחון עצמי, נוכחות וכריזמה אותנטית</li>
          <li>להשפיע על הצד השני באופן תת-הכרתי</li>
          <li>להפוך למי שכולם מרגישים מולו פתוחים יותר</li>
        </ul>
        <div class="lp-cta-row">
          <a href="#register" class="lp-btn">הרשמה עכשיו ←</a>
          <div class="lp-price-tag">
            <span class="lp-price-old">3,000 ₪</span>
            <strong>1,600 ₪ בלבד</strong>
            <span>מתחילים 23.10.26</span>
          </div>
        </div>
      </div>
      <div class="lp-hero-image">
        <img src="/images/maayan-hero.png" alt="מעיין בשן" />
      </div>
    </section>

    <section class="lp-section lp-video-section">
      <div class="lp-inner lp-center">
        <div class="lp-eyebrow">רגע לפני שממשיכים</div>
        <h2>הכירו את מעיין — בדקה וחצי</h2>
        <div class="lp-video">
          <iframe
            src="https://www.youtube-nocookie.com/embed/aRz4WRds2rE"
            title="סרטון פתיחה - מעיין בשן"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <div class="lp-trust-bar">
      <div><span>15+</span> שנות ניסיון</div>
      <div><span>אלפי</span> בוגרים</div>
      <div><span>5</span> מפגשים אינטנסיביים</div>
      <div><span>#1</span> בשפת גוף בישראל</div>
    </div>

    <section class="lp-section">
      <div class="lp-inner lp-story-grid">
        <div>
          <div class="lp-eyebrow">הסיפור שמאחורי השיטה</div>
          <h2>איך הפכתי<br />למומחית שפת גוף</h2>
        </div>
        <div class="lp-story-text">
          <p>הייתי בת 21, מוכרת רצפות עץ, כשהופיע עורך דין מרשים. חליפה נוצצת, הצעה מפתה — אבל משהו בעיניים, בידיים, בקול לא הסתדר לי. הבטן צעקה לברוח, אבל שיתפתי פעולה.</p>
          <p>שלוש שנים של שגשוג — עד שביום בהיר הוא נעלם עם 300,000 ₪. המשכתי. הקמתי עסק, נישאתי, ילדתי. ואז רואה חשבון חדש, עיניים שלא פגשו את שלי. שוב התעלמתי. שוב — התרסקות. חוב של 1.7 מיליון ₪.</p>
          <blockquote class="lp-oath">
            <em>"באותו לילה נשבעתי:</em><br />
            אני אלמד את השפה שהגוף מדבר. אדע הכל על אנשים בלי שיוציאו מילה."
          </blockquote>
          <p>ומאז לא הפסקתי: מאות שעות תרגול, עשרות קורסים, אלפי תלמידים. פיתחתי שיטה. היא עובדת — לא רק בשבילי, אלא גם עבורכם.</p>
        </div>
      </div>
    </section>

    <section class="lp-section lp-section-cream">
      <div class="lp-inner">
        <div class="lp-eyebrow">מה תלמדו</div>
        <h2>5 יכולות שנכנסות לגוף שלכם</h2>
        <p class="lp-section-desc">לא רשימת מושגים. כל יכולת נבנית במפגש אחד, מתורגמת לתרגיל אחד, ונכנסת לשימוש באותו שבוע.</p>
        <div class="lp-outcomes">
          {outcomes.map((o, i) => (
            <div class="lp-outcome">
              <div class="lp-outcome-num">{i + 1}</div>
              <div>
                <h3>{o.title}</h3>
                <p>{o.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="lp-section">
      <div class="lp-inner">
        <div class="lp-eyebrow">לוח זמנים</div>
        <h2>5 מפגשים × 5 שעות</h2>
        <p class="lp-section-desc">ימי שישי בבוקר, 9:00–14:00, הרצליה</p>
        <div class="lp-schedule">
          <div class="lp-schedule-header">
            <span class="lp-emoji">📅</span>
            <h3>אוקטובר–נובמבר 2026 — הרצליה</h3>
          </div>
          <div class="lp-dates">
            {dates.map((d) => <span class="lp-date-pill">{d}</span>)}
          </div>
          <div class="lp-meta-grid">
            <div class="lp-meta-item">
              <span class="lp-emoji">🕘</span>
              <div><h4>שעות</h4><p>9:00 עד 14:00 בכל מפגש</p></div>
            </div>
            <div class="lp-meta-item">
              <span class="lp-emoji">📍</span>
              <div><h4>מיקום</h4><p>הרצליה — חניה חינם, מרחב נעים ומרווח</p></div>
            </div>
            <div class="lp-meta-item">
              <span class="lp-emoji">👥</span>
              <div><h4>קבוצה קטנה</h4><p>מספר המקומות מוגבל — הרשמה מוקדמת מומלצת</p></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="lp-section lp-section-cream">
      <div class="lp-inner">
        <div class="lp-eyebrow">מחיר</div>
        <h2>השקעה שמשנה חיים</h2>
        <p class="lp-section-desc">קורסי שפת גוף ברמה דומה עולים 4,000–9,000 ₪. פגישה אישית בלבד — מעל 1,000 ₪ לשעה.</p>
        <div class="lp-price-grid">
          <div class="lp-price-card">
            <div class="lp-price-label">מחיר לנרשמים מכאן</div>
            <div class="lp-price-was">מחיר מקורי: 3,000 ₪</div>
            <div class="lp-price-now">1,600 <span>₪</span></div>
            <p>ידע פרקטי, כלים מעשיים ותרגול חי — כמחצית המחיר של קורסים מקבילים.</p>
            <a href="#register" class="lp-btn">הרשמה עכשיו ←</a>
            <div class="lp-urgency"><span class="lp-urgency-dot"></span> נותרו מקומות אחרונים בלבד</div>
          </div>
          <div class="lp-bonus-card">
            <span class="lp-bonus-tag">🎁 בונוס מיוחד</span>
            <h3>סשן אישי עם מעיין</h3>
            <p>כרטיס להגרלה לסשן אישי של שעה וחצי עם מעיין בשן — אבחון ושדרוג שפת הגוף שלך. כל נרשם מקבל כרטיס.</p>
            <div class="lp-bonus-value">שווי 2,100 ₪</div>
            <hr />
            <p class="lp-small">ביטול והחזר מלא עד שבוע לפני תחילת הקורס.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="lp-section lp-instant-section">
      <div class="lp-inner lp-instant">
        <div>
          <span class="lp-instant-tag">⚡ הטבה לרוכשים עכשיו</span>
          <h3>1,500 ₪ בלבד — רק למי שמשלים רכישה מיידית</h3>
          <p>ההנחה חלה אוטומטית בתשלום באתר עכשיו. לא נשמרת, לא חוזרת — מי שמשלים תשלום אחר כך משלם 1,600 ₪.</p>
        </div>
        <a href={PAYMENT_URL} target="_blank" rel="noopener" class="lp-btn lp-btn-light">לתשלום מיידי — 1,500 ₪ ←</a>
      </div>
    </section>

    <section class="lp-section">
      <div class="lp-inner lp-faq-inner">
        <div class="lp-eyebrow">שאלות נפוצות</div>
        <h2>יש לכם שאלות?</h2>
        <div class="lp-faq-list">
          {faqs.map((f) => (
            <details class="lp-faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="lp-section lp-section-cream">
      <div class="lp-inner lp-about">
        <div class="lp-about-photo">
          <img src="/images/maayan-about.png" alt="מעיין בשן" />
        </div>
        <div>
          <div class="lp-eyebrow">קצת עליי</div>
          <h2 class="lp-about-title">מעיין בשן</h2>
          <p>אני לא מלמדת שפת גוף מתוך ספרים. למדתי אותה מתוך שני קרבות שעלו לי ביוקר — וזה מה שגרם לי לא לעזוב את התחום הזה אף פעם, גם כשהיה הרבה יותר קל לפנות למשהו אחר.</p>
          <p>היום אני מלווה בכירים, פוליטיקאים ואנשי תקשורת, נותנת חוות דעת מומחה בבתי משפט, ומלמדת באקדמיה ובארגונים. אבל המקום שבו אני נטענת באמת הוא חמש שעות עם קבוצה קטנה, כשאני רואה איך מישהו לומד לראות מה שפעם החמיץ.</p>
          <p>אם הגעתם עד כאן — כבר יש לכם תחושה שזה רלוונטי לכם. אני אשמח לפגוש אתכם באולם.</p>
          <div class="lp-signature">— מעיין</div>
        </div>
      </div>
    </section>

    <section class="lp-section lp-video-section">
      <div class="lp-inner lp-center">
        <div class="lp-eyebrow">מה אומרים המשתתפים</div>
        <h2>אל תאמינו לנו — תאמינו להם</h2>
        <div class="lp-video">
          <iframe
            src="https://www.youtube-nocookie.com/embed/rxPRA4RouCs"
            title="המלצות משתתפים - מעיין בשן"
            loading="lazy"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </section>

    <section class="lp-section" id="register">
      <div class="lp-inner">
        <div class="lp-form-wrap">
          <div class="lp-eyebrow lp-center">הרשמה לקורס</div>
          <h2 class="lp-center">הצטרפו לקורס<br />ניתוח גוף פתוח</h2>
          <p class="lp-center">5 מפגשים שישנו את האופן שבו אתם רואים אנשים (ואת עצמכם). המקומות מוגבלים.</p>
          <form name="course-registration" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="course-registration" />
            <p class="lp-hidden-field"><label>אל תמלאו שדה זה: <input name="bot-field" /></label></p>
            <div class="lp-form-row">
              <label>שם מלא<input type="text" name="name" required /></label>
              <label>מייל<input type="email" name="email" required /></label>
            </div>
            <label>טלפון<input type="tel" name="phone" required /></label>
            <button type="submit">אני רוצה ללמוד שפת גוף! ←</button>
          </form>
          <div class="lp-form-success" hidden>
            <p>נרשמת בהצלחה! נחזור אליך בהקדם 🎉</p>
            <p class="lp-pay-now">רוצים להבטיח את המקום עכשיו ולקבל את מחיר הרכישה המיידית?</p>
            <a href={PAYMENT_URL} target="_blank" rel="noopener" class="lp-btn">לתשלום מאובטח — 1,500 ₪ ←</a>
          </div>
          <p class="lp-form-error" hidden>אירעה תקלה בשליחה. נסו שוב או צרו קשר ישירות.</p>
          <p class="lp-disclaimer">מחיר מיוחד 1,600 ₪ בלבד (במקום 3,000 ₪). נחזור אליכם בהקדם.</p>
        </div>
      </div>
    </section>

    <Footer />

    <script is:inline>
      const form = document.querySelector('form[name="course-registration"]');
      const successMessage = document.querySelector('.lp-form-success');
      const errorMessage = document.querySelector('.lp-form-error');
      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        errorMessage?.setAttribute('hidden', '');
        const formData = new FormData(form);
        const encode = Array.from(formData.entries())
          .map(([key, value]) => encodeURIComponent(key) + '=' + encodeURIComponent(String(value)))
          .join('&');

        // Lead goes to two places: Netlify Forms (email notification + backup)
        // and the CRM via the course-lead function. Success if either landed.
        const netlifyForms = fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: encode,
        }).then((r) => r.ok);

        const crm = fetch('/api/course-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: formData.get('name'),
            email: formData.get('email'),
            phone: formData.get('phone'),
          }),
        }).then((r) => r.ok).catch(() => false);

        Promise.allSettled([netlifyForms, crm]).then((results) => {
          const anyOk = results.some((r) => r.status === 'fulfilled' && r.value === true);
          if (anyOk) {
            form.hidden = true;
            successMessage?.removeAttribute('hidden');
          } else {
            errorMessage?.removeAttribute('hidden');
          }
        });
      });
    </script>
  </body>
</html>

<style>
  .lp-hero h1,
  .lp-section h2,
  .lp-section h3,
  .lp-section h4,
  .lp-instant h3 {
    font-family: 'Heebo', 'Assistant', sans-serif;
  }

  .lp-video-section { padding-top: 3rem; padding-bottom: 3rem; }
  .lp-video {
    max-width: 760px;
    margin: 1.5rem auto 0;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.14);
  }
  .lp-video iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
  }

  .lp-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 2rem;
    background: var(--color-cream);
    box-shadow: 0 1px 8px rgba(0, 0, 0, 0.06);
  }
