---
import Footer from '../components/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import '../styles/global.css';

const PAYMENT_URL = 'https://secure.cardcom.solutions/EA/EA5/VEmNO09CUOPMpERwwew/PaymentSP';

const dates = ['6.1', '13.1', '20.1', '27.1', '3.2', '10.2'];

const modules = [
  {
    title: 'אלימות והפרעות אישיות',
    text: 'שפת גוף שמנבאת אלימות, ומאפיינים גופניים של הפרעות אישיות - כולל פסיכופתיה. תלמדו לזהות אותות אזהרה לפני שהם הופכים למילים.',
  },
  {
    title: 'זוגיות, דייטים וחדר האמיתות',
    text: 'קריאת אותות אמת ומשיכה במרחב הכי אינטימי שיש - מפגישה ראשונה ועד חדר השינה. מה הגוף מגלה כשהמילים משתיקות.',
  },
  {
    title: 'סטוריטלינג עם אמנון וולף',
    text: 'איך מספרים סיפור ומלבישים אותו בשפת גוף שמחזיקה קהל - מפגש ייחודי יחד עם השחקן אמנון וולף.',
  },
  {
    title: 'שקרים - הרצאה שלמה',
    text: 'לא עוד סימן אחד או שניים. צלילה מלאה לזיהוי שקרים ומניפולציות ברמה מקצועית, מעבר לכל מה שנלמד בקורס הבסיסי.',
  },
  {
    title: 'משא ומתן',
    text: 'לקרוא את הצד השני באמצע המשא ומתן, לדעת מתי לדחוף ומתי לעצור, ולנהל את הגוף שלכם כך שישרת אתכם בשולחן.',
  },
];

const faqs = [
  {
    q: 'האם הקורס מתאים למי שלא סיים את הקורס הבסיסי?',
    a: 'לא. הקורס המתקדם מיועד אך ורק לבוגרי הקורס הבסיסי "ניתוח גוף פתוח" של מעיין בשן - הוא בנוי כהמשך ישיר, לא כמבוא.',
  },
  {
    q: 'מה ההבדל מהקורס הבסיסי?',
    a: 'הקורס הבסיסי מלמד את השפה עצמה מאפס. הקורס המתקדם תוקף את שפת הגוף לפי זוויות - אלימות, זוגיות, שקרים, משא ומתן - עם הרבה יותר תרגול מעשי: מיקרו-הבעות ועמידה מול קהל ומצלמה.',
  },
  {
    q: 'כמה משתתפים בקבוצה?',
    a: 'עד 40 בוגרים בלבד, כדי לשמור על רמת תרגול אישי גבוהה בכל מפגש.',
  },
  {
    q: 'מה אם אפסיד מפגש?',
    a: 'אפשר להשלים בקורס הבא או לקבל גישה להקלטת המפגש שהחסרתם.',
  },
  {
    q: 'מה קורה בכל מפגש בפועל?',
    a: 'שעה וחצי הרצאה על הנושא של אותו מפגש, ואחריה שעה וחצי תרגול מעשי צמוד עם מעיין ופידבק מיידי - מיקרו-הבעות, סימולציות, ועמידה מול קהל ומצלמה.',
  },
  {
    q: 'מה תנאי הביטול?',
    a: 'ביטול והחזר מלא אפשרי עד שבוע לפני תחילת הקורס.',
    extra: {
      title: 'נספח – מדיניות ביטול השתתפות בקורס',
      intro: 'משתתף המבקש לבטל את השתתפותו בקורס יודיע על כך בכתב, באמצעות אחת מהדרכים הבאות:',
      contacts: ['WhatsApp: 050-558-5177', 'דוא"ל: maayan.inst@gmail.com'],
      rules: [
        'במקרה של ביטול ההשתתפות עד 7 ימים לפני מועד פתיחת הקורס, יינתן החזר כספי מלא.',
        'במקרה של ביטול ההשתתפות החל מ־7 ימים ועד 3 ימים לפני מועד פתיחת הקורס, יינתן החזר בשיעור של 50% מעלות הקורס.',
        'במקרה של ביטול ההשתתפות פחות מ־3 ימים לפני פתיחת הקורס, או לאחר תחילת הקורס, לא יינתן החזר כספי.',
      ],
      outro: 'מועד קבלת הודעת הביטול בכתב אצל מפעילת הקורס הוא שייחשב כמועד הביטול לצורך חישוב הזכאות להחזר. הוראות נספח זה יחולו בכפוף להוראות כל דין, ובכל מקרה שבו קיימת לצרכן זכות שאינה ניתנת להתניה לפי חוק, יחולו הוראות הדין המחייבות.',
    },
  },
];
---
<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>שפת גוף - קורס מתקדמים | מעיין בשן</title>
    <meta name="description" content='קורס המשך בלעדי לבוגרי "ניתוח גוף פתוח" - 6 מפגשי העשרה ותרגול מעשי אינטנסיבי עם מעיין בשן. אלימות, זוגיות, שקרים ומשא ומתן.' />
    <meta name="keywords" content="מעיין בשן, מעין בשן, שפת גוף, שפתגוף, קורס מתקדמים, ניתוח גוף פתוח" />
    <meta name="google-site-verification" content="eP1EVt4zfY7kOhKGsSnLYR49MPqn7bKNlRavQqKDkGo" />
    <link rel="canonical" href="https://maayanbashan.co.il/body-language-advanced-course" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Assistant:wght@400;500;600;700&family=Heebo:wght@400;600;700&family=Bellefair&display=swap" rel="stylesheet" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="שפת גוף - קורס מתקדמים | מעיין בשן" />
    <meta property="og:description" content='קורס המשך בלעדי לבוגרי "ניתוח גוף פתוח" - 6 מפגשים, ינואר-פברואר 2027, הרצליה' />
    <meta property="og:url" content="https://maayanbashan.co.il/body-language-advanced-course" />
    <meta property="og:image" content="https://maayanbashan.co.il/images/maayan-hero.png" />
    <meta property="og:locale" content="he_IL" />
    <meta property="og:site_name" content="מעיין בשן" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Structured data: Course -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Course',
      name: 'שפת גוף - קורס מתקדמים',
      description: 'קורס המשך לבוגרי "ניתוח גוף פתוח" - 6 מפגשי העשרה ותרגול מעשי: אלימות והפרעות אישיות, זוגיות ודייטים, סטוריטלינג, שקרים, משא ומתן.',
      provider: {
        '@type': 'Person',
        name: 'מעיין בשן',
        sameAs: 'https://maayanbashan.co.il',
      },
      offers: {
        '@type': 'Offer',
        price: '3800',
        priceCurrency: 'ILS',
        availability: 'https://schema.org/InStock',
        url: 'https://maayanbashan.co.il/body-language-advanced-course',
      },
      hasCourseInstance: {
        '@type': 'CourseInstance',
        courseMode: 'Onsite',
        location: {
          '@type': 'Place',
          name: 'אשכול פייס, הרצליה',
        },
        startDate: '2027-01-06',
      },
    })} />
  </head>
  <body>
    <nav class="ac-nav">
      <a href="/" class="ac-logo"><img src="/images/logo-teal.png" alt="מעיין בשן" /></a>
      <a href="#register" class="ac-nav-cta">הרשמה לקורס</a>
    </nav>

    <!-- HERO -->
    <section class="ac-hero">
      <div class="ac-hero-shapes" aria-hidden="true">
        <span class="ac-shape ac-shape-diamond1"></span>
        <span class="ac-shape ac-shape-diamond2"></span>
      </div>
      <div class="ac-hero-text">
        <div class="ac-badge">🎓 לבוגרי הקורס הבסיסי בלבד</div>
        <div class="ac-eyebrow-pill">✦ שפת גוף · קורס מתקדמים · ינואר 2027</div>
        <h1>מנתחים עמוק יותר.<br /><em class="ac-marker">מתרגלים הרבה יותר</em>.</h1>
        <p class="ac-hero-sub">קורס ההמשך הבלעדי של מעיין בשן — 6 מפגשי העשרה ותרגול אינטנסיבי, לרמה מקצועית</p>
        <ul class="ac-bullets">
          <li>לזהות אלימות והפרעות אישיות דרך שפת הגוף</li>
          <li>לקרוא שפת גוף בזוגיות, בדייטים ובחדר האמיתות</li>
          <li>לספר סיפור ולהלביש אותו בשפת גוף - עם אמנון וולף</li>
          <li>לשלוט במשא ומתן ולזהות שקרים ברמה מקצועית</li>
        </ul>
        <div class="ac-cta-row">
          <a href="#register" class="ac-btn ac-btn-hero">הרשמה עכשיו ←</a>
          <div class="ac-price-tag">
            <span class="ac-price-old">4,400 ₪</span>
            <strong>3,800 ₪ בלבד</strong>
            <span>מתחילים 6.1.27 · אשכול פייס, הרצליה</span>
          </div>
        </div>
      </div>
      <div class="ac-hero-image">
        <span class="ac-hero-frame" aria-hidden="true"></span>
        <img src="/images/maayan-hero.png" alt="מעיין בשן" />
      </div>
    </section>

    <!-- TRUST BAR -->
    <div class="ac-trust-bar">
      <div><span>15+</span>שנות ניסיון</div>
      <div><span>40</span>מקומות בלבד</div>
      <div><span>6</span>מפגשי העשרה</div>
      <div><span>1:1</span>יחס תרגול-הרצאה</div>
    </div>

    <!-- PRACTICE EMPHASIS -->
    <section class="ac-section ac-practice-section reveal">
      <div class="ac-inner ac-center">
        <div class="ac-eyebrow">מה שמבדיל את הקורס הזה</div>
        <h2>לא עוד קורס <em class="ac-marker-strike">ידע</em>.<br />קורס <em class="ac-marker">יכולת</em>.</h2>
        <p class="ac-practice-lead">
          הכוח של הקורס המתקדם לא נמצא רק בהרצאות - הוא נמצא בשעות התרגול. כל נושא שלומדים באותו ערב, מתרגלים באותו ערב: מול מעיין, מול הקבוצה, מול מצלמה, עם פידבק מיידי על כל תזוזה. יוצאים עם דבר שאפשר להשתמש בו כבר למחרת - לא רק עם עוד ידע תיאורטי.
        </p>
        <div class="ac-practice-grid">
          <div class="ac-practice-card">
            <span class="ac-practice-num">01</span>
            <h3>לומדים</h3>
            <p>שעה וחצי הרצאה מעמיקה על הזווית של אותו מפגש</p>
          </div>
          <div class="ac-practice-arrow" aria-hidden="true">←</div>
          <div class="ac-practice-card">
            <span class="ac-practice-num">02</span>
            <h3>מתרגלים</h3>
            <p>שעה וחצי תרגול מעשי צמוד - מיקרו-הבעות, סימולציות, מול קהל ומצלמה</p>
          </div>
          <div class="ac-practice-arrow" aria-hidden="true">←</div>
          <div class="ac-practice-card ac-practice-card-gold">
            <span class="ac-practice-num">03</span>
            <h3>יוצאים עם יכולת</h3>
            <p>פידבק מיידי על כל תרגיל, בכל מפגש - לא ידע שנשאר על הנייר</p>
          </div>
        </div>
      </div>
    </section>

    <!-- MODULES -->
    <section class="ac-section ac-section-alt reveal">
      <div class="ac-inner">
        <div class="ac-eyebrow">מה לומדים</div>
        <h2>5 זוויות <em class="ac-marker">שלא הספקנו</em> בקורס הבסיסי</h2>
        <p class="ac-section-desc">כל מפגש תוקף את שפת הגוף מזווית אחרת, ומיד אחר כך - תרגול מעשי על אותה זווית בדיוק.</p>
        <div class="ac-modules">
          {modules.map((m, i) => (
            <div class="ac-module">
              <span class="ac-module-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <div class="ac-module-body">
                <h3>{m.title}</h3>
                <p>{m.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- GUEST: AMNON WOLF -->
    <section class="ac-section reveal">
      <div class="ac-inner ac-guest-grid">
        <div class="ac-guest-photos">
          <img src="/images/advanced-course/maayan-amnon-piggyback.jpg" alt="מעיין בשן ואמנון וולף" class="ac-guest-photo-main" />
          <img src="/images/advanced-course/maayan-amnon-back-to-back.jpg" alt="מעיין בשן ואמנון וולף" class="ac-guest-photo-accent" />
        </div>
        <div class="ac-guest-text">
          <div class="ac-eyebrow">אורח מיוחד במפגש הסטוריטלינג</div>
          <h2>מעיין בשן <em class="ac-marker-soft">ואמנון וולף</em></h2>
          <p>אחד המפגשים המיוחדים בקורס נעשה בשיתוף השחקן אמנון וולף - איך מספרים סיפור, ואיך מלבישים אותו בשפת גוף שגורמת לקהל להישאר איתכם עד המילה האחרונה.</p>
        </div>
      </div>
    </section>

    <!-- SCHEDULE -->
    <section class="ac-section ac-section-alt reveal">
      <div class="ac-inner">
        <div class="ac-eyebrow">לוח זמנים</div>
        <h2>6 מפגשים <em class="ac-marker-soft">מעמיקים</em></h2>
        <p class="ac-section-desc">ימי רביעי · 17:00–21:00 · אשכול פייס, הרצליה · ינואר–פברואר 2027</p>
        <div class="ac-tickets">
          {dates.map((d, i) => (
            <div class="ac-ticket">
              <span class="ac-ticket-day">רביעי</span>
              <span class="ac-ticket-date">{d}</span>
              <span class="ac-ticket-num">מפגש {i + 1}</span>
            </div>
          ))}
        </div>
        <div class="ac-meta-grid">
          <div class="ac-meta-item">
            <span class="ac-emoji">🕘</span>
            <div><h4>שעות</h4><p>17:00 עד 21:00 בכל מפגש</p></div>
          </div>
          <div class="ac-meta-item">
            <span class="ac-emoji">📍</span>
            <div><h4>מיקום</h4><p>אשכול פייס, הרצליה</p></div>
          </div>
          <div class="ac-meta-item">
            <span class="ac-emoji">🎓</span>
            <div><h4>קהל יעד</h4><p>רק לבוגרי הקורס הבסיסי · עד 40 משתתפים</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- PRICE -->
    <section class="ac-section reveal">
      <div class="ac-inner">
        <div class="ac-eyebrow">מחיר</div>
        <h2>השקעה <em class="ac-marker-soft">ברמה הבאה</em></h2>
        <p class="ac-section-desc">שישה מפגשים מרוכזים, יחס גבוה במיוחד בין הרצאה לתרגול מעשי אישי מול מעיין.</p>
        <div class="ac-price-grid">
          <div class="ac-price-card">
            <div class="ac-price-label">מחיר מיוחד לבוגרים</div>
            <div class="ac-price-was">מחיר מקורי: 4,400 ₪</div>
            <div class="ac-price-now">3,800 <span>₪</span></div>
            <p>שישה מפגשים, שלוש שעות כל מפגש - הרצאה מעמיקה ותרגול מעשי צמוד עם פידבק מיידי.</p>
            <a href="#register" class="ac-btn">הרשמה עכשיו ←</a>
            <div class="ac-urgency"><span class="ac-urgency-dot"></span> עד 40 בוגרים בלבד</div>
          </div>
          <div class="ac-info-card">
            <span class="ac-info-tag">🎓 למי זה מתאים</span>
            <h3>רק לבוגרי הקורס הבסיסי</h3>
            <p>קורס ההמשך בנוי במיוחד למי שכבר עבר את "ניתוח גוף פתוח" ורוצה לתקוף את השפה לעומק - לא עוד מבוא, אלא עבודה מעשית לפי זוויות.</p>
            <hr />
            <p class="ac-small">ביטול והחזר מלא עד שבוע לפני תחילת הקורס.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- PAYMENT BANNER -->
    <section class="ac-section ac-instant-section reveal">
      <div class="ac-inner ac-instant">
        <div>
          <span class="ac-instant-tag">💳 מוכנים להעמיק?</span>
          <h3>אפשר להשלים את ההרשמה והתשלום כאן ועכשיו</h3>
          <p>תשלום מאובטח בכרטיס אשראי. עד 40 מקומות בלבד לקבוצה.</p>
        </div>
        <a href={PAYMENT_URL} target="_blank" rel="noopener" class="ac-btn ac-btn-light">לתשלום מאובטח — 3,800 ₪ ←</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="ac-section ac-section-alt reveal">
      <div class="ac-inner ac-faq-inner">
        <div class="ac-eyebrow">שאלות נפוצות</div>
        <h2>יש לכם שאלות?</h2>
        <div class="ac-faq-list">
          {faqs.map((f) => (
            <details class="ac-faq-item">
              <summary>{f.q}<span class="ac-faq-plus" aria-hidden="true">+</span></summary>
              <p>{f.a}</p>
              {f.extra && (
                <div class="ac-faq-addendum">
                  <h4>{f.extra.title}</h4>
                  <p>{f.extra.intro}</p>
                  <ul class="ac-faq-contacts">
                    {f.extra.contacts.map((c) => <li>{c}</li>)}
                  </ul>
                  <ol class="ac-faq-rules">
                    {f.extra.rules.map((r) => <li>{r}</li>)}
                  </ol>
                  <p class="ac-faq-fine">{f.extra.outro}</p>
                </div>
              )}
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- REGISTRATION -->
    <section class="ac-section ac-register-section reveal" id="register">
      <div class="ac-register-shapes" aria-hidden="true">
        <span class="ac-shape ac-shape-diamond3"></span>
      </div>
      <div class="ac-inner">
        <div class="ac-form-wrap">
          <div class="ac-eyebrow ac-center">הרשמה לקורס</div>
          <h2 class="ac-center">הצטרפו לקורס<br />שפת גוף - מתקדמים</h2>
          <p class="ac-center">קורס ההמשך הבלעדי לבוגרים. עד 40 מקומות בלבד.</p>
          <form name="advanced-course-registration" method="POST" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="advanced-course-registration" />
            <p class="ac-hidden-field"><label>אל תמלאו שדה זה: <input name="bot-field" /></label></p>
            <div class="ac-form-row">
              <label>שם מלא<input type="text" name="name" required /></label>
              <label>מייל<input type="email" name="email" required /></label>
            </div>
            <label>טלפון<input type="tel" name="phone" required /></label>
            <button type="submit">אני רוצה להעמיק בשפת הגוף! ←</button>
          </form>
          <div class="ac-form-success" hidden>
            <p>נרשמת בהצלחה! נחזור אליך בהקדם 🎉</p>
            <p class="ac-pay-now">רוצים להבטיח את המקום כבר עכשיו?</p>
            <a href={PAYMENT_URL} target="_blank" rel="noopener" class="ac-btn">לתשלום מאובטח — 3,800 ₪ ←</a>
          </div>
          <p class="ac-form-error" hidden>אירעה תקלה בשליחה. נסו שוב או צרו קשר ישירות.</p>
          <p class="ac-disclaimer">מחיר מיוחד 3,800 ₪ בלבד (במקום 4,400 ₪). נחזור אליכם בהקדם.</p>
        </div>
      </div>
    </section>

    <Footer />
    <FloatingWhatsApp message="היי מעיין, אני בוגר/ת הקורס הבסיסי ומעוניין/ת בקורס המתקדמים (ינואר 2027) ואשמח לפרטים נוספים" />

    <script is:inline>
      const form = document.querySelector('form[name="advanced-course-registration"]');
      const submitButton = form?.querySelector('button[type="submit"]');
      const successMessage = document.querySelector('.ac-form-success');
      const errorMessage = document.querySelector('.ac-form-error');
      let isSubmitting = false;
      form?.addEventListener('submit', (event) => {
        event.preventDefault();
        if (isSubmitting) return;
        isSubmitting = true;
        if (submitButton) {
          submitButton.disabled = true;
          submitButton.dataset.originalText = submitButton.textContent ?? '';
          submitButton.textContent = 'שולח...';
        }
        errorMessage?.setAttribute('hidden', '');
        const formData = new FormData(form);
        const encode = Array.from(formData.entries())
          .map(([key, value]) => encodeURIComponent(key) + '=' + encodeURIComponent(String(value)))
          .join('&');

        const netlifyForms = fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: encode,
        }).then((r) => r.ok);

        const crm = fetch('/api/advanced-course-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: formData.get('name'),
            email: formData.get('email'),
            phone: formData.get('phone'),
          }),
        }).then((r) => r.ok).catch(() => false);

        Promise.allSettled([netlifyForms, crm]).then((results) => {
          const anyOk = results.some((r) => r.status === 'fulfilled' && r.value === true);
          if (anyOk) {
            form.hidden = true;
            successMessage?.removeAttribute('hidden');
          } else {
            errorMessage?.removeAttribute('hidden');
            isSubmitting = false;
            if (submitButton) {
              submitButton.disabled = false;
              submitButton.textContent = submitButton.dataset.originalText ?? submitButton.textContent;
            }
          }
        });
      });

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.01, rootMargin: '0px 0px -10% 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
      } else {
        document.querySelectorAll('.reveal').forEach((el) => el.classList.add('in-view'));
      }
    </script>
  </body>
