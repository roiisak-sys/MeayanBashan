---
import BaseLayout from '../layouts/BaseLayout.astro';
import PartnerLogos from '../components/PartnerLogos.astro';
import { getEntry } from 'astro:content';

const org = await getEntry('organizations', 'organizations');
---
<BaseLayout title="ארגונים" description="הרצאות וסדנאות לארגונים וחברות">
  <section class="organizations-page reveal">
    {org?.data.tag && <span class="eyebrow">{org.data.tag}</span>}
    <h1>{org?.data.title}</h1>
    {org?.data.intro && <p class="intro">{org.data.intro}</p>}
    {org?.data.benefits && (
      <div class="benefits-grid">
        {org.data.benefits.map((b) => (
          <div class="benefit-card">
            <span class="check" aria-hidden="true">✓</span>
            <div>
              <h3>{b.title}</h3>
              <p>{b.description}</p>
            </div>
          </div>
        ))}
      </div>
    )}
    {org?.data.closing && <p class="closing">{org.data.closing}</p>}
  </section>

  <PartnerLogos />
  <section class="business-contact reveal">
    <div class="form-wrap">
      <span class="eyebrow">בואו נתאים לכם תוכנית</span>
      <h2>מעוניינים לארגון שלכם?</h2>
      <form name="business-contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="business-contact" />
        <p class="hidden-field"><label>אל תמלאו שדה זה: <input name="bot-field" /></label></p>
        <div class="form-row">
          <label>שם מלא<input type="text" name="name" required /></label>
          <label>שם הארגון<input type="text" name="company" required /></label>
        </div>
        <div class="form-row">
          <label>טלפון<input type="tel" name="phone" required /></label>
          <label>מייל<input type="email" name="email" required /></label>
        </div>
        <label>פרטים נוספים<textarea name="message" rows="4"></textarea></label>
        <button type="submit" class="btn btn-orange">שליחה ←</button>
      </form>
      <p class="form-success" hidden>תודה! ההודעה נשלחה בהצלחה, נחזור אליכם בהקדם.</p>
      <p class="form-error" hidden>משהו השתבש. נסו שוב או צרו קשר ישירות בטלפון/במייל.</p>
    </div>
  </section>
</BaseLayout>
<style>
  .organizations-page { max-width: 820px; margin: 0 auto; padding: 4rem 2rem 3rem; }
  .organizations-page h1 { color: var(--color-teal); font-size: clamp(2rem, 4vw, 2.5rem); margin-bottom: 1.25rem; }
  .intro { line-height: 1.8; margin-bottom: 2.25rem; font-size: 1.1rem; max-width: 620px; }
  .closing { line-height: 1.85; margin-top: 2.5rem; font-size: 1.02rem; color: var(--color-text); opacity: 0.85; }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .benefit-card {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    background: var(--color-cream);
    border-radius: 4px 16px 16px 16px;
    padding: 1.25rem 1.4rem;
    box-shadow: var(--shadow-hard);
  }
  .benefit-card .check {
    flex-shrink: 0;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--color-teal);
    color: var(--paper);
    font-size: 0.85rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.2rem;
  }
  .benefit-card h3 { color: var(--color-teal); font-size: 1.05rem; margin-bottom: 0.3rem; }
  .benefit-card p { margin: 0; font-size: 0.92rem; line-height: 1.6; }
  @media (max-width: 620px) {
    .benefits-grid { grid-template-columns: 1fr; }
  }

  .business-contact { padding: 1rem 2rem 4.5rem; }
  .form-wrap {
    max-width: 620px;
    margin: 0 auto;
    background: var(--paper);
    border: 3px solid var(--ink);
    border-radius: 20px;
    padding: 2.75rem 2.25rem;
    box-shadow: 0.6rem 0.6rem 0 var(--color-orange);
    text-align: center;
  }
  .form-wrap .eyebrow { text-align: center; }
  .form-wrap h2 { color: var(--color-teal); margin-bottom: 1.75rem; }
  form { display: flex; flex-direction: column; gap: 1.1rem; text-align: start; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem; }
  label { display: flex; flex-direction: column; gap: 0.35rem; font-weight: 700; font-size: 0.95rem; }
  input, textarea {
    padding: 0.7rem;
    border-radius: 10px;
    border: 2px solid rgba(15, 50, 41, 0.25);
    font-family: inherit;
    font-size: 1rem;
    background: var(--color-cream);
    transition: border-color 0.15s ease;
  }
  input:focus, textarea:focus { outline: none; border-color: var(--color-teal); }
  .hidden-field { display: none; }
  button[type="submit"] { align-self: center; margin-top: 0.5rem; }
  .form-success, .form-error { text-align: center; font-weight: 700; margin-top: 1.25rem; }
  .form-success { color: var(--color-teal); }
  .form-error { color: var(--color-red); }
  [hidden] { display: none; }
  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
    .form-wrap { padding: 2rem 1.5rem; }
  }
</style>
<script>
  const form = document.querySelector<HTMLFormElement>('form[name="business-contact"]');
  const successMessage = document.querySelector<HTMLElement>('.form-success');
  const errorMessage = document.querySelector<HTMLElement>('.form-error');

  const encode = (data: FormData) =>
    Array.from(data.entries())
      .map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`)
      .join('&');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    errorMessage?.setAttribute('hidden', '');

    const formData = new FormData(form);

    fetch('/', {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: encode(formData),
    })
      .then((response) => {
        if (!response.ok) throw new Error('Form submission failed');
        form.hidden = true;
        successMessage?.removeAttribute('hidden');
      })
      .catch(() => {
        errorMessage?.removeAttribute('hidden');
      });
  });
</script>
