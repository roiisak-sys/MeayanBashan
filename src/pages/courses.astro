---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const courses = await getCollection('courses');
const renderedCourses = await Promise.all(
  courses.map(async (course) => ({ course, Content: (await render(course)).Content }))
);
---
<BaseLayout title="הרצאות וקורסים" description="הרצאות וקורסים של מעיין בשן">
  <section class="courses-page reveal">
    <span class="eyebrow">מה מעיין מלמדת</span>
    <h1>הרצאות <em class="marker">וקורסים</em></h1>
    <div class="courses-list">
      {renderedCourses.map(({ course, Content }, i) => (
        <article class={`course-card ${i % 2 ? 'tilt-r' : 'tilt-l'}`}>
          {course.data.image && <img src={course.data.image} alt={course.data.title} />}
          <div class="course-body">
            <h2>{course.data.title}</h2>
            <p class="format">{course.data.format}</p>
            <div class="description"><Content /></div>
            <a class="btn btn-teal" href={course.data.contactLink}>ליצירת קשר להרשמה ←</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
<style>
  .courses-page { max-width: 900px; margin: 0 auto; padding: 4rem 2rem; text-align: center; }
  .courses-page h1 { color: var(--color-teal); margin-bottom: 2.5rem; font-size: clamp(2rem, 4vw, 2.75rem); }
  .courses-list { text-align: start; }
  .course-card {
    display: flex;
    gap: 1.5rem;
    padding: 1.75rem;
    margin-bottom: 1.75rem;
    background: var(--color-cream);
    border-radius: 4px 18px 18px 18px;
    box-shadow: var(--shadow-hard);
  }
  .tilt-l { transform: rotate(-0.6deg); }
  .tilt-r { transform: rotate(0.6deg); }
  .course-card img { width: 160px; height: 160px; object-fit: cover; border-radius: 10px; flex-shrink: 0; }
  .course-body h2 { color: var(--color-teal); font-size: 1.35rem; margin-bottom: 0.35rem; }
  .format { font-family: var(--font-serif); color: var(--color-red); font-weight: 700; }
  @media (max-width: 640px) {
    .course-card { flex-direction: column; transform: none; }
    .course-card img { width: 100%; height: auto; }
  }
</style>
