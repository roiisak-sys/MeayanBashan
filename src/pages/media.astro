---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const mediaItems = (await getCollection('media')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryLabels: Record<string, string> = {
  tv: 'טלוויזיה',
  podcast: 'פודקאסטים',
  article: 'כתבות ופינות',
  other: 'אחר',
};

// When no image was uploaded, derive a thumbnail from YouTube links automatically
function youtubeThumbnail(url: string): string | null {
  const match = url.match(
    /(?:youtube\.com\/(?:watch\?(?:.*&)?v=|shorts\/|embed\/|live\/)|youtu\.be\/)([\w-]{11})/
  );
  return match ? `https://i.ytimg.com/vi/${match[1]}/hqdefault.jpg` : null;
}

function cardImage(item: (typeof mediaItems)[number]): string | null {
  return item.data.image ?? youtubeThumbnail(item.data.url);
}
---
<BaseLayout title="תקשורת" description="אזכורים תקשורתיים של מעיין בשן">
  <section class="media-page reveal">
    <span class="eyebrow">כפי שהופיעה</span>
    <h1>ב<em class="marker">תקשורת</em></h1>
    <div class="filters">
      <button data-filter="all" class="active">הכל</button>
      {Object.entries(categoryLabels).map(([key, label]) => (
        <button data-filter={key}>{label}</button>
      ))}
    </div>
    <div class="media-grid">
      {mediaItems.map((item) => (
        <a class="media-card" data-category={item.data.category} href={item.data.url} target="_blank" rel="noopener">
          {cardImage(item) && <img src={cardImage(item)} alt={item.data.title} loading="lazy" />}
          <span class="category-tag">{categoryLabels[item.data.category]}</span>
          <h3>{item.data.title}</h3>
          {item.data.description && <p>{item.data.description}</p>}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
<style>
  .media-page { max-width: 1100px; margin: 0 auto; padding: 4rem 2rem; text-align: center; }
  .media-page h1 { color: var(--color-teal); margin-bottom: 2rem; font-size: clamp(2rem, 4vw, 2.75rem); }
  .filters { display: flex; justify-content: center; gap: 0.75rem; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .filters button {
    font-family: var(--font-display);
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    border: 2px solid var(--color-teal);
    background: var(--paper);
    color: var(--color-teal);
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .filters button.active { background: var(--color-teal); color: white; }
  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.75rem;
    text-align: start;
  }
  .media-card {
    display: block;
    padding: 1.1rem;
    border-radius: 4px 16px 16px 16px;
    background: var(--color-cream);
    text-decoration: none;
    color: var(--color-text);
    box-shadow: var(--shadow-hard);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .media-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 0.8rem 0.8rem 0 rgba(15, 50, 41, 0.2);
  }
  .media-card img { width: 100%; border-radius: 8px; margin-bottom: 0.75rem; aspect-ratio: 16/9; object-fit: cover; }
  .media-card h3 { font-size: 1.1rem; margin: 0.3rem 0; }
  .category-tag {
    display: inline-block;
    font-family: var(--font-serif);
    font-size: 0.75rem;
    color: var(--color-red);
    font-weight: 700;
  }
</style>
<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filters button');
  const cards = document.querySelectorAll<HTMLElement>('.media-card');

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.remove('active'));
      button.classList.add('active');
      const filter = button.dataset.filter;
      cards.forEach((card) => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.style.display = show ? 'block' : 'none';
      });
    });
  });
</script>
