---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const mediaItems = (await getCollection('media')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// When no image was uploaded, derive a thumbnail from YouTube links automatically
function youtubeThumbnail(url: string): string | null {
  const match = url.match(
    /(?:youtube\.com\/(?:watch\?(?:.*&)?v=|shorts\/|embed\/|live\/)|youtu\.be\/)([\w-]{11})/
  );
  return match ? `https://i.ytimg.com/vi/${match[1]}/hqdefault.jpg` : null;
}

function cardImage(item: (typeof mediaItems)[number]): string | null {
  return item.data.image ?? youtubeThumbnail(item.data.url);
}

const sections = [
  {
    key: 'podcast',
    title: 'פודקאסט "ניתוח גוף פתוח"',
    items: mediaItems.filter((i) => i.data.category === 'podcast'),
  },
  {
    key: 'tv',
    title: 'טלוויזיה',
    items: mediaItems.filter((i) => i.data.category === 'tv'),
  },
  {
    key: 'article',
    title: 'עיתונות',
    items: mediaItems.filter((i) => i.data.category === 'article'),
  },
  {
    key: 'other',
    title: 'אירוח בפודקאסטים',
    items: mediaItems.filter((i) => i.data.category === 'other'),
  },
].filter((section) => section.items.length > 0);
---
<BaseLayout title="מהמדיה" description="מעיין בשן מהמדיה - פודקאסט, טלוויזיה ועיתונות">
  <section class="media-hero reveal">
    <span class="eyebrow">כפי שהופיעה</span>
    <h1>מ<em class="marker">המדיה</em></h1>
  </section>

  {sections.map((section) => (
    <section class="media-section reveal" id={section.key}>
      <div class="media-inner">
        <h2>{section.title}</h2>
        <div class="media-grid">
          {section.items.map((item) => (
            <a class="media-card" href={item.data.url} target="_blank" rel="noopener">
              {cardImage(item) && <img src={cardImage(item)} alt={item.data.title} loading="lazy" />}
              <h3>{item.data.title}</h3>
              {item.data.description && <p>{item.data.description}</p>}
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>
<style>
  .media-hero { max-width: 1100px; margin: 0 auto; padding: 4rem 2rem 1rem; text-align: center; }
  .media-hero h1 { color: var(--color-teal); font-size: clamp(2.2rem, 5vw, 3rem); }
  .media-hero .eyebrow { text-align: center; }

  .media-section { padding: 3rem 2rem; }
  .media-section:nth-of-type(odd) { background: var(--color-cream); }
  .media-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
  .media-inner > .eyebrow { text-align: center; }
  .media-inner h2 { color: var(--color-teal); margin-bottom: 2rem; font-size: clamp(1.5rem, 3.5vw, 2rem); }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.75rem;
    text-align: start;
  }
  .media-card {
    display: block;
    padding: 1.1rem;
    border-radius: 4px 16px 16px 16px;
    background: var(--paper);
    text-decoration: none;
    color: var(--color-text);
    box-shadow: var(--shadow-hard);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .media-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: 0.8rem 0.8rem 0 rgba(15, 50, 41, 0.2);
  }
  .media-card img { width: 100%; border-radius: 8px; margin-bottom: 0.75rem; aspect-ratio: 16/9; object-fit: cover; }
  .media-card h3 { font-size: 1.05rem; margin: 0.2rem 0; }
  .media-card p { margin: 0.4rem 0 0; font-size: 0.9rem; opacity: 0.8; }
</style>
